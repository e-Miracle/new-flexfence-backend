PORT=8080
APP_ENV=development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=flexfence
DB_AUTO_MIGRATE=true
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=72
GOOGLE_CLIENT_ID=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Dashboard URL (linked in OTP emails)
DASHBOARD_URL=http://localhost:5173

# Public HTTPS base for join links encoded in QR (optional; falls back to flexfence:// deep link)
# JOIN_PUBLIC_BASE_URL=https://app.example.com

# SMTP (required for real OTP delivery; if unset, codes are logged to the API stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FlexFence

# Business login OTP
OTP_LENGTH=4
OTP_EXPIRE_MINUTES=10
