# Production environment for docker-compose.prod.yml on the server.
# Copy to /opt/flexfence/backend/.env and fill in secrets.

PORT=8080
APP_ENV=production

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=flexfence
DB_PASSWORD=change-me
DB_NAME=flexfence
DB_AUTO_MIGRATE=true

JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=72

GOOGLE_CLIENT_ID=

CORS_ALLOWED_ORIGINS=https://app.flexfence.app,https://flexfence.app
DASHBOARD_URL=https://app.flexfence.app
JOIN_PUBLIC_BASE_URL=https://app.flexfence.app

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FlexFence

OTP_LENGTH=4
OTP_EXPIRE_MINUTES=10
