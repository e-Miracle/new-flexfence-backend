# Template only — create this file on the SERVER at /opt/flexfence/backend/.env (not deployed by CI).
# docker-compose.prod.yml includes a MySQL container; DB_HOST is set to "mysql" automatically.

PORT=8080
APP_ENV=production

# App database user (also used to initialize the MySQL container)
DB_USER=flexfence
DB_PASSWORD=
DB_NAME=flexfence
DB_PORT=3306
DB_AUTO_MIGRATE=true

# MySQL root password (for the bundled mysql service only)
MYSQL_ROOT_PASSWORD=

JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=72

GOOGLE_CLIENT_ID=

CORS_ALLOWED_ORIGINS=https://app.flexfence.app,https://flexfence.app
DASHBOARD_URL=https://app.flexfence.app
JOIN_PUBLIC_BASE_URL=https://app.flexfence.app

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FlexFence

OTP_LENGTH=4
OTP_EXPIRE_MINUTES=10
